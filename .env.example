# Copy this file to .env and fill in real values. Never commit .env.

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campus_db"

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (required — server refuses to start without it)
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""
JWT_EXPIRY="7d"

# CORS Configuration — comma-separated list of allowed browser origins
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# Email Configuration (required in production for OTP login;
# in development OTPs are logged to the server console if unset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Campus Placement <your-email@gmail.com>"

# OTP Configuration
OTP_EXPIRY_MINUTES=10
